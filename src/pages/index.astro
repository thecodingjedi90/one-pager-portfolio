---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import SkillSection from '../components/SkillSection.astro';

// Import data from JSON files
import resumeData from '../data/resume.json';
import achievementsData from '../data/achievements.json';
---

<Layout 
  title={`${resumeData.basics.name} - ${resumeData.basics.label}`}
  description={resumeData.basics.summary}
>
  <!-- Header Section -->
  <Header basics={resumeData.basics} />

  <!-- Tab Navigation -->
  <div class="bg-white border-b border-gray-200 no-print">
    <div class="max-w-7xl mx-auto px-6">
      <nav class="flex gap-8" role="tablist">
        <button
          id="tab-professional"
          role="tab"
          aria-selected="true"
          aria-controls="panel-professional"
          class="px-4 py-4 text-base font-semibold border-b-2 border-brand-accent text-brand-accent transition-colors"
        >
          Professional Accomplishment
        </button>
        <button
          id="tab-other"
          role="tab"
          aria-selected="false"
          aria-controls="panel-other"
          class="px-4 py-4 text-base font-semibold border-b-2 border-transparent text-gray-600 hover:text-brand-primary hover:border-gray-300 transition-colors"
        >
          Other Achievements
        </button>
      </nav>
    </div>
  </div>

  <!-- Tab Panels -->
  <main class="max-w-7xl mx-auto px-6 py-8">
    
    <!-- Panel 1: Professional Accomplishment -->
    <div id="panel-professional" role="tabpanel" aria-labelledby="tab-professional">
    
    <!-- Section 1: Sidebar Layout (Summary + Technical Exposure with Sidebar) -->
    <div class="flex flex-col lg:flex-row gap-8 mb-10">
      
      <!-- Left Sidebar -->
      <aside class="lg:w-80 flex-shrink-0 space-y-6">
        
        <!-- Education Section -->
        <section class="section-spacing">
          <h2 class="text-xl font-bold text-brand-primary mb-4 border-b-2 border-brand-accent pb-2">
            Education
          </h2>
          <div class="space-y-4">
          {resumeData.education.map((edu) => (
            <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-brand-accent">
              <h3 class="text-base font-bold text-brand-primary mb-1">{edu.studyType}</h3>
              <p class="text-sm text-gray-700 mb-1">{edu.area}</p>
              <p class="text-sm text-gray-600 mb-2">{edu.institution}</p>
              <div class="flex justify-between items-center">
                <span class="text-xs text-gray-600 font-medium">{edu.endDate}</span>
                {edu.score && (
                  <span class="text-xs text-brand-accent font-semibold">GPA: {edu.score}</span>
                )}
              </div>
            </div>
          ))}
          </div>
        </section>

        <!-- Certifications Section -->
        <section class="section-spacing">
          <h2 class="text-xl font-bold text-brand-primary mb-4 border-b-2 border-brand-accent pb-2">
            Certifications
          </h2>
          <div class="space-y-2">
            {resumeData.certificates.map((cert) => (
              <div class="bg-white rounded-lg shadow-sm p-3 border-l-4 border-tech-salesforce hover:shadow-md transition-shadow">
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 text-tech-salesforce flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                  </svg>
                  <span class="text-sm font-medium text-gray-800 leading-tight">
                    {cert.name}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </section>
      </aside>

      <!-- Main Content Area (Summary + Technical Exposure) -->
      <div class="flex-1 min-w-0">
        
        <!-- Summary Section -->
        <section class="mb-10 section-spacing">
          <h2 class="text-2xl font-bold text-brand-primary mb-4 border-b-2 border-brand-accent pb-2">
            Professional Summary
          </h2>
          <p class="text-gray-700 leading-relaxed">
            {resumeData.basics.summary}
          </p>
        </section>

        <!-- Technical Exposure Section -->
        <section class="mb-10 section-spacing">
          <h2 class="text-2xl font-bold text-brand-primary mb-6 border-b-2 border-brand-accent pb-2">
            Technical Exposure
          </h2>
          <ul class="space-y-3">
            {resumeData.technicalExposure.map((item) => (
              <li class="flex items-start gap-3 text-gray-700">
                <svg 
                  class="w-5 h-5 mt-0.5 flex-shrink-0 text-brand-accent" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="flex-1">{item}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>
    </div>

    <!-- Section 2: Full Width Content (Other Initiatives, Experience, Skills) -->
    <div class="max-w-5xl mx-auto">
      
      <!-- Other Development Initiatives Section -->
      <section class="mb-10 section-spacing">
        <h2 class="text-2xl font-bold text-brand-primary mb-6 border-b-2 border-brand-accent pb-2">
          Other Development Initiatives
        </h2>
        <ul class="space-y-3">
          {resumeData.otherInitiatives.map((item) => (
            <li class="flex items-start gap-3 text-gray-700">
              <svg 
                class="w-5 h-5 mt-0.5 flex-shrink-0 text-tech-amazon" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              <span class="flex-1">{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Experience Section -->
      <section class="mb-10 section-spacing">
        <h2 class="text-2xl font-bold text-brand-primary mb-6 border-b-2 border-brand-accent pb-2">
          Professional Experience
        </h2>
        <div class="space-y-0">
          {resumeData.work.map((job, index) => (
            <ExperienceItem work={job} isFirst={index === 0} />
          ))}
        </div>
      </section>

      <!-- Skills Section -->
      <section class="mb-10 section-spacing">
        <h2 class="text-2xl font-bold text-brand-primary mb-6 border-b-2 border-brand-accent pb-2">
          Technical Skills
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {resumeData.skills.map((skill) => (
            <SkillSection skill={skill} />
          ))}
        </div>
      </section>

    </div>
    
    </div>
    <!-- End Panel 1: Professional Accomplishment -->

    <!-- Panel 2: Coding and Architecture -->
    <div id="panel-other" role="tabpanel" aria-labelledby="tab-other" class="hidden">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-primary mb-8">Coding and Architecture</h2>
        
        <!-- 3-Column Card Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {achievementsData.achievements.map((achievement) => (
            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-200 hover:border-brand-accent group">
              <!-- Image Section -->
              <div class="relative h-48 overflow-hidden bg-gradient-to-br from-brand-accent/10 to-tech-salesforce/10">
                <img 
                  src={`${import.meta.env.BASE_URL}${achievement.image}`}
                  alt={achievement.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 400 300\'%3E%3Crect fill=\'%234f46e5\' width=\'400\' height=\'300\'/%3E%3Ctext x=\'50%25\' y=\'50%25\' font-size=\'48\' fill=\'white\' text-anchor=\'middle\' dy=\'.3em\' font-family=\'Inter, sans-serif\' font-weight=\'bold\'%3E%F0%9F%8F%86%3C/text%3E%3C/svg%3E'"
                />
                <!-- Date Badge -->
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-gray-700">
                  {new Date(achievement.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </div>
              </div>
              <!-- Content Section -->
              <div class="p-5">
                <h3 class="text-lg font-bold text-brand-primary mb-2 group-hover:text-brand-accent transition-colors">
                  {achievement.title}
                </h3>
                <p 
                  class="text-sm text-gray-600 leading-relaxed"
                  set:html={achievement.description}
                />
              </div>
            </div>
          ))}
        </div>

        <!-- Badges Section -->
        <section class="mt-16">
          <h2 class="text-3xl font-bold text-brand-primary mb-8 border-b-2 border-brand-accent pb-2">
            Badges
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
            {achievementsData.badges && achievementsData.badges.map((badge) => (
              <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-300 p-4 flex flex-col items-center justify-center border border-gray-200 hover:border-brand-accent group">
                <img 
                  src={`${import.meta.env.BASE_URL}${badge.image}`}
                  alt={badge.name}
                  class="w-20 h-20 object-contain mb-2 group-hover:scale-110 transition-transform duration-300"
                  onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'%3E%3Ccircle cx=\'50\' cy=\'50\' r=\'45\' fill=\'%234f46e5\'/%3E%3Ctext x=\'50%25\' y=\'50%25\' font-size=\'48\' fill=\'white\' text-anchor=\'middle\' dy=\'.3em\'%3E%F0%9F%8F%85%3C/text%3E%3C/svg%3E'"
                />
                <p class="text-xs text-center text-gray-700 font-medium leading-tight">
                  {badge.name}
                </p>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
    <!-- End Panel 2: Coding and Architecture -->

  </main>

  <!-- Tab Switching Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('[role="tab"]');
      const panels = document.querySelectorAll('[role="tabpanel"]');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Remove active state from all tabs
          tabs.forEach(t => {
            t.setAttribute('aria-selected', 'false');
            t.classList.remove('border-brand-accent', 'text-brand-accent');
            t.classList.add('border-transparent', 'text-gray-600');
          });

          // Hide all panels
          panels.forEach(panel => {
            panel.classList.add('hidden');
          });

          // Activate clicked tab
          tab.setAttribute('aria-selected', 'true');
          tab.classList.remove('border-transparent', 'text-gray-600');
          tab.classList.add('border-brand-accent', 'text-brand-accent');

          // Show corresponding panel
          const panelId = tab.getAttribute('aria-controls');
          if (panelId) {
            const panel = document.getElementById(panelId);
            if (panel) {
              panel.classList.remove('hidden');
            }
          }
        });
      });
    });
  </script>

  <!-- Footer -->
  <footer class="bg-brand-primary text-white py-6 mt-12 no-print">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="text-sm text-gray-300">
        © {new Date().getFullYear()} {resumeData.basics.name}. Built with Astro & Tailwind CSS.
      </p>
    </div>
  </footer>
</Layout>