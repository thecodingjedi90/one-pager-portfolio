---
interface Props {
  basics: {
    name: string;
    label: string;
    email: string;
    phone: string;
    url: string;
    location: {
      city: string;
      countryCode: string;
    };
    profiles: Array<{
      network: string;
      url: string;
    }>;
  };
}

const { basics } = Astro.props;
---

<header class="bg-brand-primary text-white px-6 py-8 section-spacing">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-6 mb-4">
      <!-- Profile Image -->
      <img 
        src={`${import.meta.env.BASE_URL}/profile.png`}
        alt={basics.name}
        class="w-24 h-24 rounded-full border-4 border-white shadow-lg object-cover"
      />
      
      <!-- Name and Title -->
      <div>
        <h1 class="text-4xl font-bold mb-2">{basics.name}</h1>
        <p class="text-xl text-gray-300">{basics.label}</p>
      </div>
    </div>
    
    <div class="flex flex-wrap gap-4 text-sm">
      <!-- Email -->
      <a 
        href={`mailto:${basics.email}`} 
        class="flex items-center gap-2 hover:text-brand-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span>{basics.email}</span>
      </a>
      
      <!-- Phone -->
      <a 
        href={`tel:${basics.phone}`} 
        class="flex items-center gap-2 hover:text-brand-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span>{basics.phone}</span>
      </a>
      
      <!-- Location -->
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span>{basics.location.city}, {basics.location.countryCode}</span>
      </div>
      
      <!-- LinkedIn -->
      {basics.profiles.map((profile) => (
        <a 
          href={profile.url} 
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 hover:text-brand-accent transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>{profile.network}</span>
        </a>
      ))}
      
      <!-- Trailblazer -->
      <a 
        href={basics.url} 
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 hover:text-tech-salesforce transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <span>Trailblazer</span>
      </a>
    </div>
  </div>
</header>