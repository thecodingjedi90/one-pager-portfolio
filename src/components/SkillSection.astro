---
interface Props {
  skill: {
    name: string;
    keywords: string[];
  };
}

const { skill } = Astro.props;

// Icon mapping for different skill categories
const getIconColor = (name: string) => {
  if (name.includes('Salesforce')) return 'text-tech-salesforce';
  if (name.includes('Cloud') || name.includes('AI')) return 'text-tech-amazon';
  if (name.includes('DevOps')) return 'text-brand-accent';
  return 'text-gray-600';
};
---

<div class="bg-white rounded-lg shadow-sm p-5 border-l-4 border-brand-accent">
  <h3 class={`text-lg font-bold mb-3 ${getIconColor(skill.name)}`}>
    {skill.name}
  </h3>
  
  <div class="flex flex-wrap gap-2">
    {skill.keywords.map((keyword) => (
      <span class="inline-flex items-center px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
        {keyword}
      </span>
    ))}
  </div>
</div>