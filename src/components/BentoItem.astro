---
interface Props {
  achievement: {
    title: string;
    description: string;
    image: string;
    date: string;
  };
  size?: 'small' | 'medium' | 'large';
}

const { achievement, size = 'medium' } = Astro.props;

// Format date
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};

// Size classes for bento grid
const sizeClasses = {
  small: 'col-span-1 row-span-1',
  medium: 'col-span-1 md:col-span-2 row-span-1',
  large: 'col-span-1 md:col-span-2 lg:col-span-3 row-span-2'
};
---

<div 
  class={`${sizeClasses[size]} bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-200 hover:border-brand-accent group`}
>
  <!-- Image Section -->
  <div class="relative h-48 overflow-hidden bg-gradient-to-br from-brand-accent/10 to-tech-salesforce/10">
    <img 
      src={achievement.image} 
      alt={achievement.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 400 300\'%3E%3Crect fill=\'%234f46e5\' width=\'400\' height=\'300\'/%3E%3Ctext x=\'50%25\' y=\'50%25\' font-size=\'48\' fill=\'white\' text-anchor=\'middle\' dy=\'.3em\' font-family=\'Inter, sans-serif\' font-weight=\'bold\'%3E%F0%9F%8F%86%3C/text%3E%3C/svg%3E'"
    />
    
    <!-- Date Badge -->
    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-gray-700">
      {formatDate(achievement.date)}
    </div>
  </div>

  <!-- Content Section -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-brand-primary mb-2 group-hover:text-brand-accent transition-colors">
      {achievement.title}
    </h3>
    <p 
      class="text-sm text-gray-600 leading-relaxed"
      set:html={achievement.description}
    />
  </div>
</div>